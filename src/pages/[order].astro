---
import type { GetStaticPaths } from 'astro';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ArtworkViewer from '../components/ArtworkViewer.astro';
import { getArtworks, plainText } from '../lib/artworks';
import type { OrderedArtwork } from '../types/artwork';

export const getStaticPaths = (async () => {
  const artworks = await getArtworks();
  return artworks.map((artwork) => ({
    params: { order: String(artwork.order) },
    props: { artwork, total: artworks.length },
  }));
}) satisfies GetStaticPaths;

interface Props {
  artwork: OrderedArtwork;
  total: number;
}

const { artwork, total } = Astro.props;
---

<Layout
  title={artwork.title}
  description={plainText(artwork.description) || `来自 ${artwork.author.name} 的作品`}
  canonical={`/${artwork.order}/`}
>
  <SiteHeader />
  <ArtworkViewer artwork={artwork} total={total} />
</Layout>
