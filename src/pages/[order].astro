---
import type { GetStaticPaths } from 'astro';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ArtworkViewer from '../components/ArtworkViewer.astro';
import { getArtworks, plainText } from '../lib/artworks';
import type { OrderedArtwork } from '../types/artwork';

export const getStaticPaths = (async () => {
  const artworks = await getArtworks();
  return artworks.map((artwork, index) => {
    const newerArtwork = artworks[index + 1];
    const olderArtwork = artworks[index - 1];
    const newerHref = newerArtwork
      ? (index + 1 === artworks.length - 1 ? '/' : `/${newerArtwork.sequence}/`)
      : null;
    return {
      params: { order: String(artwork.sequence) },
      props: {
        artwork,
        newerHref,
        olderHref: olderArtwork ? `/${olderArtwork.sequence}/` : null,
      },
    };
  });
}) satisfies GetStaticPaths;

interface Props {
  artwork: OrderedArtwork;
  newerHref: string | null;
  olderHref: string | null;
}

const { artwork, newerHref, olderHref } = Astro.props;
---

<Layout
  title={artwork.title}
  description={plainText(artwork.description) || `来自 ${artwork.author.name} 的作品`}
  canonical={`/${artwork.sequence}/`}
>
  <SiteHeader />
  <ArtworkViewer artwork={artwork} newerHref={newerHref} olderHref={olderHref} />
</Layout>
