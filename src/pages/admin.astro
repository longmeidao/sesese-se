---
import Layout from '../layouts/Layout.astro';
import '../styles/admin.css';
---

<Layout
  title="藏品管理"
  description="色览的私人藏品管理台"
  canonical="/admin/"
  robots="noindex, nofollow, noarchive"
>
  <main id="main-content" class="admin-page">
    <section id="admin-login" class="admin-login" aria-labelledby="admin-login-title">
      <div class="admin-login__panel">
        <a href="/" class="admin-header__back">← 返回展厅</a>
        <p class="admin-kicker">PRIVATE COLLECTION DESK</p>
        <h1 id="admin-login-title">藏品管理</h1>
        <p class="admin-login__intro">这是私人管理入口。验证通过后，才会读取藏品资料并显示管理功能。</p>

        <form id="admin-login-form" class="admin-login__form">
          <label class="admin-field">
            <span>访问密钥</span>
            <input id="admin-secret" name="secret" type="password" autocomplete="current-password" required />
          </label>
          <label class="admin-checkbox">
            <input id="keep-signed-in" type="checkbox" />
            <span>保持登录</span>
          </label>
          <small>不勾选时，关闭当前标签页后需要重新登录。</small>
          <button type="submit" class="admin-button admin-button--primary">进入管理台</button>
          <output id="login-status" aria-live="polite"></output>
        </form>
      </div>
    </section>

    <section id="admin-app" class="admin-shell" hidden>
      <header class="admin-header">
        <div>
          <a href="/" class="admin-header__back">← 返回展厅</a>
          <p class="admin-kicker">PRIVATE COLLECTION DESK</p>
          <h1>藏品管理</h1>
        </div>
        <div class="admin-header__side">
          <div class="admin-summary" aria-label="藏品状态统计">
            <span><strong id="active-count">0</strong> 展出中</span>
            <span><strong id="hidden-count">0</strong> 已隐藏</span>
            <span><strong id="deleted-count">0</strong> 回收站</span>
          </div>
          <button id="admin-logout" type="button" class="admin-button admin-button--quiet">退出管理</button>
        </div>
      </header>

      <div class="admin-workspace">
        <section class="admin-panel admin-ingest" aria-labelledby="admin-ingest-title">
          <div class="admin-panel__heading">
            <div>
              <p class="admin-panel__eyebrow">添加</p>
              <h2 id="admin-ingest-title">收录新作品</h2>
            </div>
            <a href="https://github.com/longmeidao/sesese-se/actions/workflows/ingest-artwork.yml" target="_blank" rel="noopener noreferrer">查看采集任务 ↗</a>
          </div>
          <form id="ingest-form" class="admin-form">
            <label class="admin-field admin-field--wide">
              <span>Pixiv、X 或其他来源链接</span>
              <input name="url" type="url" inputmode="url" placeholder="https://www.pixiv.net/artworks/..." required />
            </label>
            <label class="admin-field admin-field--index">
              <span>展示第几张</span>
              <input name="display_image" type="number" min="1" max="100" value="1" required />
            </label>
            <details class="admin-advanced">
              <summary>补充作品信息</summary>
              <div class="admin-advanced__grid">
                <label class="admin-field">
                  <span>标题</span>
                  <input name="title" type="text" maxlength="300" />
                </label>
                <label class="admin-field">
                  <span>作者名</span>
                  <input name="author_name" type="text" maxlength="300" />
                </label>
                <label class="admin-field admin-field--wide">
                  <span>作者页面</span>
                  <input name="author_url" type="url" inputmode="url" />
                </label>
                <label class="admin-field admin-field--wide">
                  <span>图片直链，每行一个</span>
                  <textarea name="image_urls" rows="3"></textarea>
                </label>
                <label class="admin-field admin-field--wide">
                  <span>作品说明</span>
                  <textarea name="description" rows="3"></textarea>
                </label>
                <label class="admin-field admin-field--wide">
                  <span>标签，以逗号分隔</span>
                  <input name="tags" type="text" />
                </label>
              </div>
            </details>
            <button type="submit" class="admin-button admin-button--primary">开始采集</button>
            <output id="ingest-status" aria-live="polite"></output>
          </form>
        </section>

        <aside class="admin-panel admin-runs" aria-labelledby="admin-runs-title">
          <div class="admin-panel__heading">
            <div>
              <p class="admin-panel__eyebrow">任务</p>
              <h2 id="admin-runs-title">最近采集</h2>
            </div>
            <button id="refresh-runs" type="button" class="admin-button admin-button--quiet">刷新</button>
          </div>
          <ol id="admin-runs-list">
            <li class="admin-runs__empty">正在读取采集记录…</li>
          </ol>
        </aside>
      </div>

      <section class="admin-collection" aria-labelledby="admin-collection-title">
        <div class="admin-collection__heading">
          <div>
            <p class="admin-panel__eyebrow">馆藏</p>
            <h2 id="admin-collection-title">管理作品</h2>
          </div>
          <div class="admin-filters">
            <label>
              <span class="visually-hidden">搜索藏品</span>
              <input id="artwork-search" type="search" placeholder="搜索编号、标题、作者或标签" />
            </label>
            <label>
              <span class="visually-hidden">筛选状态</span>
              <select id="artwork-status-filter">
                <option value="all">全部状态</option>
                <option value="active">展出中</option>
                <option value="hidden">已隐藏</option>
                <option value="deleted">回收站</option>
              </select>
            </label>
          </div>
        </div>

        <div id="admin-artwork-grid" class="admin-artwork-grid"></div>
        <p id="admin-empty-filter" class="admin-empty" hidden>没有符合条件的藏品。</p>
      </section>

      <dialog id="edit-artwork-dialog" class="admin-dialog">
        <form id="edit-artwork-form" method="dialog">
          <div class="admin-dialog__heading">
            <div>
              <p class="admin-panel__eyebrow">手动修改</p>
              <h2 id="edit-artwork-title">编辑藏品</h2>
            </div>
            <button type="button" data-close-dialog class="admin-dialog__close" aria-label="关闭">×</button>
          </div>
          <input name="id" type="hidden" />
          <div class="admin-override">
            <label class="admin-checkbox">
              <input name="title_auto" type="checkbox" />
              <span>使用原站标题</span>
            </label>
            <input name="title" type="text" maxlength="300" />
            <small data-source-field="title"></small>
          </div>
          <div class="admin-override">
            <label class="admin-checkbox">
              <input name="author_name_auto" type="checkbox" />
              <span>使用原站作者名</span>
            </label>
            <input name="author_name" type="text" maxlength="300" />
            <small data-source-field="author_name"></small>
          </div>
          <div class="admin-override">
            <label class="admin-checkbox">
              <input name="description_auto" type="checkbox" />
              <span>使用原站说明</span>
            </label>
            <textarea name="description" rows="5"></textarea>
            <small data-source-field="description"></small>
          </div>
          <div class="admin-override">
            <label class="admin-checkbox">
              <input name="tags_auto" type="checkbox" />
              <span>使用原站标签</span>
            </label>
            <input name="tags" type="text" />
            <small data-source-field="tags"></small>
          </div>
          <div class="admin-dialog__actions">
            <button type="button" data-close-dialog class="admin-button admin-button--quiet">取消</button>
            <button type="submit" class="admin-button admin-button--primary">保存更改</button>
          </div>
          <output id="edit-status" aria-live="polite"></output>
        </form>
      </dialog>

      <div id="admin-toast" class="admin-toast" role="status" aria-live="polite" hidden></div>
    </section>
  </main>

  <script>
    type AdminArtwork = {
      id: string;
      sequence: number;
      status: 'active' | 'hidden' | 'deleted';
      source_type: string;
      source_url: string;
      display_image_index: number;
      image: string;
      source: { title: string; description: string; tags: string[]; author_name: string };
      overrides: { title?: string; description?: string; tags?: string[]; author_name?: string };
      effective: { title: string; description: string; tags: string[]; author_name: string };
    };

    type AdminRun = {
      id: number;
      status: string;
      conclusion: string | null;
      title: string;
      url: string;
      created_at: string;
    };

    const sessionKey = 'sesese-admin-secret';
    const persistentKey = 'sesese-admin-secret-remembered';
    const login = document.querySelector<HTMLElement>('#admin-login')!;
    const app = document.querySelector<HTMLElement>('#admin-app')!;
    const loginForm = document.querySelector<HTMLFormElement>('#admin-login-form')!;
    const secretInput = document.querySelector<HTMLInputElement>('#admin-secret')!;
    const keepSignedIn = document.querySelector<HTMLInputElement>('#keep-signed-in')!;
    const loginStatus = document.querySelector<HTMLOutputElement>('#login-status')!;
    const loginButton = loginForm.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const runsList = document.querySelector<HTMLOListElement>('#admin-runs-list')!;
    const artworkGrid = document.querySelector<HTMLElement>('#admin-artwork-grid')!;
    const dialog = document.querySelector<HTMLDialogElement>('#edit-artwork-dialog')!;
    const editForm = document.querySelector<HTMLFormElement>('#edit-artwork-form')!;
    const toast = document.querySelector<HTMLDivElement>('#admin-toast')!;

    let secret = '';
    let artworks: AdminArtwork[] = [];
    let artworkById = new Map<string, AdminArtwork>();

    function showToast(message: string, error = false) {
      toast.textContent = message;
      toast.dataset.error = String(error);
      toast.hidden = false;
      window.setTimeout(() => { toast.hidden = true; }, 4200);
    }

    async function requestApi(secretValue: string, path: string, init: RequestInit = {}) {
      const response = await fetch(path, {
        ...init,
        headers: {
          authorization: `Bearer ${secretValue}`,
          ...(init.body ? { 'content-type': 'application/json' } : {}),
          ...init.headers,
        },
      });
      const body = await response.json().catch(() => ({})) as { error?: string; detail?: unknown };
      if (!response.ok) throw new Error(body.error || `请求失败（${response.status}）`);
      return body as Record<string, unknown>;
    }

    function api(path: string, init: RequestInit = {}) {
      if (!secret) throw new Error('登录状态已失效，请重新进入管理台。');
      return requestApi(secret, path, init);
    }

    function setLoginBusy(busy: boolean, message = '') {
      secretInput.disabled = busy;
      keepSignedIn.disabled = busy;
      loginButton.disabled = busy;
      loginButton.textContent = busy ? '正在验证…' : '进入管理台';
      loginStatus.textContent = message;
    }

    function saveLogin(secretValue: string) {
      sessionStorage.removeItem(sessionKey);
      localStorage.removeItem(persistentKey);
      if (keepSignedIn.checked) localStorage.setItem(persistentKey, secretValue);
      else sessionStorage.setItem(sessionKey, secretValue);
    }

    function clearLogin() {
      secret = '';
      artworks = [];
      artworkById.clear();
      sessionStorage.removeItem(sessionKey);
      localStorage.removeItem(persistentKey);
      secretInput.value = '';
      keepSignedIn.checked = false;
    }

    function formatRunState(status: string, conclusion?: string | null) {
      if (status !== 'completed') return '进行中';
      if (conclusion === 'success') return '已完成';
      if (conclusion === 'cancelled') return '已取消';
      return '未完成';
    }

    function renderRuns(runs: AdminRun[]) {
      runsList.replaceChildren();
      if (runs.length === 0) {
        const empty = document.createElement('li');
        empty.className = 'admin-runs__empty';
        empty.textContent = '还没有采集记录。';
        runsList.append(empty);
        return;
      }

      for (const run of runs) {
        const item = document.createElement('li');
        const link = document.createElement('a');
        link.href = run.url;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        const title = document.createElement('span');
        title.textContent = run.title;
        const meta = document.createElement('small');
        meta.textContent = `${formatRunState(run.status, run.conclusion)} · ${new Date(run.created_at).toLocaleString('zh-CN')}`;
        link.append(title, meta);
        item.append(link);
        runsList.append(item);
      }
    }

    function statusLabel(status: AdminArtwork['status']) {
      if (status === 'active') return '展出中';
      if (status === 'hidden') return '已隐藏';
      return '回收站';
    }

    function actionButton(label: string, options: { action?: string; status?: AdminArtwork['status']; danger?: boolean } = {}) {
      const button = document.createElement('button');
      button.type = 'button';
      button.textContent = label;
      button.className = `admin-button admin-button--small${options.danger ? ' admin-button--danger' : ''}`;
      if (options.action) button.dataset.action = options.action;
      if (options.status) button.dataset.statusChange = options.status;
      return button;
    }

    function renderArtworkCard(artwork: AdminArtwork) {
      const card = document.createElement('article');
      card.className = 'admin-artwork';
      card.dataset.artworkId = artwork.id;
      card.dataset.status = artwork.status;
      card.dataset.search = `${artwork.sequence} ${artwork.effective.title} ${artwork.effective.author_name} ${artwork.effective.tags.join(' ')}`.toLowerCase();

      const image = document.createElement('img');
      image.src = artwork.image;
      image.width = 180;
      image.height = 180;
      image.alt = '';
      image.loading = 'lazy';
      image.decoding = 'async';

      const body = document.createElement('div');
      body.className = 'admin-artwork__body';
      const meta = document.createElement('div');
      meta.className = 'admin-artwork__meta';
      const number = document.createElement('span');
      number.textContent = `No. ${String(artwork.sequence).padStart(3, '0')}`;
      const status = document.createElement('span');
      status.className = `admin-status admin-status--${artwork.status}`;
      status.textContent = statusLabel(artwork.status);
      meta.append(number, status);

      const title = document.createElement('h3');
      title.textContent = artwork.effective.title;
      const author = document.createElement('p');
      author.textContent = `${artwork.effective.author_name} · ${artwork.source_type}`;
      const tags = document.createElement('div');
      tags.className = 'admin-artwork__tags';
      for (const tag of artwork.effective.tags.slice(0, 3)) {
        const item = document.createElement('span');
        item.textContent = `#${tag}`;
        tags.append(item);
      }

      const actions = document.createElement('div');
      actions.className = 'admin-artwork__actions';
      actions.append(actionButton('编辑', { action: 'edit' }));
      if (['pixiv', 'x'].includes(artwork.source_type)) {
        actions.append(actionButton('重新抓取', { action: 'reingest' }));
      }
      if (artwork.status === 'active') actions.append(actionButton('隐藏', { status: 'hidden' }));
      if (artwork.status === 'hidden') actions.append(actionButton('恢复展出', { status: 'active' }));
      if (artwork.status !== 'deleted') {
        actions.append(actionButton('移入回收站', { status: 'deleted', danger: true }));
      } else {
        actions.append(actionButton('恢复', { status: 'active' }));
      }

      body.append(meta, title, author, tags, actions);
      card.append(image, body);
      return card;
    }

    function updateSummary() {
      document.querySelector('#active-count')!.textContent = String(artworks.filter((item) => item.status === 'active').length);
      document.querySelector('#hidden-count')!.textContent = String(artworks.filter((item) => item.status === 'hidden').length);
      document.querySelector('#deleted-count')!.textContent = String(artworks.filter((item) => item.status === 'deleted').length);
    }

    function renderArtworks() {
      artworkGrid.replaceChildren(...artworks.map(renderArtworkCard));
      updateSummary();
      filterArtworks();
    }

    async function loadRuns() {
      const loading = document.createElement('li');
      loading.className = 'admin-runs__empty';
      loading.textContent = '正在读取采集记录…';
      runsList.replaceChildren(loading);
      const result = await api('/api/admin/runs');
      renderRuns((result.runs ?? []) as AdminRun[]);
    }

    async function enterAdmin(secretValue: string) {
      setLoginBusy(true, '正在确认访问权限…');
      try {
        const [artworkResult, runResult] = await Promise.all([
          requestApi(secretValue, '/api/admin/artworks'),
          requestApi(secretValue, '/api/admin/runs'),
        ]);
        secret = secretValue;
        artworks = (artworkResult.artworks ?? []) as AdminArtwork[];
        artworkById = new Map(artworks.map((artwork) => [artwork.id, artwork]));
        saveLogin(secretValue);
        renderArtworks();
        renderRuns((runResult.runs ?? []) as AdminRun[]);
        login.hidden = true;
        app.hidden = false;
        setLoginBusy(false);
      } catch (error) {
        setLoginBusy(false, error instanceof Error ? error.message : '无法进入管理台');
        secretInput.focus();
      }
    }

    loginForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const candidate = secretInput.value.trim();
      if (candidate) enterAdmin(candidate);
    });

    document.querySelector('#admin-logout')?.addEventListener('click', () => {
      clearLogin();
      app.hidden = true;
      login.hidden = false;
      setLoginBusy(false);
      secretInput.focus();
    });

    document.querySelector('#refresh-runs')?.addEventListener('click', () => {
      loadRuns().catch((error) => showToast(error instanceof Error ? error.message : '无法刷新采集记录', true));
    });

    document.querySelector<HTMLFormElement>('#ingest-form')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const output = document.querySelector<HTMLOutputElement>('#ingest-status')!;
      const formData = new FormData(form);
      const payload = Object.fromEntries(
        [...formData.entries()]
          .map(([key, value]) => [key, typeof value === 'string' ? value.trim() : value])
          .filter(([, value]) => value !== ''),
      );
      payload.display_image = Number(payload.display_image || 1);
      output.textContent = '正在提交…';
      try {
        await api('/api/ingest', { method: 'POST', body: JSON.stringify(payload) });
        output.textContent = '已提交。采集完成后，网站会自动更新。';
        form.reset();
        const displayInput = form.elements.namedItem('display_image') as HTMLInputElement | null;
        if (displayInput) displayInput.value = '1';
        window.setTimeout(() => loadRuns().catch(() => {}), 1800);
      } catch (error) {
        output.textContent = error instanceof Error ? error.message : '提交失败';
      }
    });

    function setAutomaticState(field: string) {
      const automatic = editForm.elements.namedItem(`${field}_auto`) as HTMLInputElement;
      const control = editForm.elements.namedItem(field) as HTMLInputElement | HTMLTextAreaElement;
      control.disabled = automatic.checked;
    }

    for (const field of ['title', 'author_name', 'description', 'tags']) {
      const automatic = editForm.elements.namedItem(`${field}_auto`) as HTMLInputElement;
      automatic.addEventListener('change', () => setAutomaticState(field));
    }

    function openEditor(artwork: AdminArtwork) {
      (editForm.elements.namedItem('id') as HTMLInputElement).value = artwork.id;
      document.querySelector('#edit-artwork-title')!.textContent = `编辑 No. ${String(artwork.sequence).padStart(3, '0')}`;
      const values: Record<string, string> = {
        title: artwork.overrides.title ?? artwork.source.title,
        author_name: artwork.overrides.author_name ?? artwork.source.author_name,
        description: artwork.overrides.description ?? artwork.source.description,
        tags: (artwork.overrides.tags ?? artwork.source.tags).join(', '),
      };
      for (const field of ['title', 'author_name', 'description', 'tags']) {
        const automatic = editForm.elements.namedItem(`${field}_auto`) as HTMLInputElement;
        const control = editForm.elements.namedItem(field) as HTMLInputElement | HTMLTextAreaElement;
        automatic.checked = !Object.prototype.hasOwnProperty.call(artwork.overrides, field);
        control.value = values[field];
        setAutomaticState(field);
        const source = document.querySelector<HTMLElement>(`[data-source-field="${field}"]`);
        if (source) {
          const sourceValue = field === 'tags'
            ? artwork.source.tags.join(', ')
            : artwork.source[field as keyof typeof artwork.source];
          source.textContent = `原站内容：${sourceValue || '无'}`;
        }
      }
      document.querySelector<HTMLOutputElement>('#edit-status')!.textContent = '';
      dialog.showModal();
    }

    for (const closeButton of document.querySelectorAll('[data-close-dialog]')) {
      closeButton.addEventListener('click', () => dialog.close());
    }

    editForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = (editForm.elements.namedItem('id') as HTMLInputElement).value;
      const artwork = artworkById.get(id);
      const output = document.querySelector<HTMLOutputElement>('#edit-status')!;
      const overrides: Record<string, string | string[] | null> = {};
      for (const field of ['title', 'author_name', 'description', 'tags']) {
        const automatic = editForm.elements.namedItem(`${field}_auto`) as HTMLInputElement;
        const control = editForm.elements.namedItem(field) as HTMLInputElement | HTMLTextAreaElement;
        overrides[field] = automatic.checked
          ? null
          : field === 'tags'
            ? control.value.split(',').map((tag) => tag.trim().replace(/^#/, '')).filter(Boolean)
            : control.value;
      }
      output.textContent = '正在保存…';
      try {
        await api(`/api/admin/artworks/${encodeURIComponent(id)}`, {
          method: 'PATCH',
          body: JSON.stringify({ overrides }),
        });
        if (artwork) {
          artwork.overrides = Object.fromEntries(
            Object.entries(overrides).filter(([, value]) => value !== null),
          ) as AdminArtwork['overrides'];
          artwork.effective = {
            title: artwork.overrides.title ?? artwork.source.title,
            author_name: artwork.overrides.author_name ?? artwork.source.author_name,
            description: artwork.overrides.description ?? artwork.source.description,
            tags: artwork.overrides.tags ?? artwork.source.tags,
          };
          renderArtworks();
        }
        output.textContent = '更改已保存，网站更新后生效。';
        showToast('更改已保存。');
        window.setTimeout(() => dialog.close(), 900);
      } catch (error) {
        output.textContent = error instanceof Error ? error.message : '保存失败';
      }
    });

    artworkGrid.addEventListener('click', async (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>('button');
      const card = button?.closest<HTMLElement>('[data-artwork-id]');
      if (!button || !card) return;
      const id = card.dataset.artworkId!;
      const artwork = artworkById.get(id);
      if (!artwork) return;

      if (button.dataset.action === 'edit') {
        openEditor(artwork);
        return;
      }

      if (button.dataset.action === 'reingest') {
        const input = window.prompt('要展示原作中的第几张图片？', String(artwork.display_image_index));
        if (input === null) return;
        const displayImage = Number(input);
        if (!Number.isInteger(displayImage) || displayImage < 1 || displayImage > 100) {
          showToast('请输入 1 到 100 之间的整数。', true);
          return;
        }
        button.disabled = true;
        try {
          await api('/api/admin/reingest', {
            method: 'POST',
            body: JSON.stringify({ id, display_image: displayImage }),
          });
          showToast('已提交重新抓取任务。');
          window.setTimeout(() => loadRuns().catch(() => {}), 1800);
        } catch (error) {
          showToast(error instanceof Error ? error.message : '无法重新抓取', true);
        } finally {
          button.disabled = false;
        }
        return;
      }

      const nextStatus = button.dataset.statusChange as AdminArtwork['status'] | undefined;
      if (!nextStatus) return;
      const prompt = nextStatus === 'deleted'
        ? '要把这件藏品移入回收站吗？30 天内仍可恢复。'
        : nextStatus === 'hidden'
          ? '要暂时隐藏这件藏品吗？'
          : '要恢复这件藏品吗？';
      if (!window.confirm(prompt)) return;
      card.classList.add('admin-artwork--pending');
      button.disabled = true;
      try {
        await api(`/api/admin/artworks/${encodeURIComponent(id)}`, {
          method: 'PATCH',
          body: JSON.stringify({ status: nextStatus }),
        });
        artwork.status = nextStatus;
        renderArtworks();
        showToast('状态已保存，网站更新后生效。');
      } catch (error) {
        card.classList.remove('admin-artwork--pending');
        button.disabled = false;
        showToast(error instanceof Error ? error.message : '无法更改藏品状态', true);
      }
    });

    function filterArtworks() {
      const query = (document.querySelector<HTMLInputElement>('#artwork-search')?.value ?? '').trim().toLowerCase();
      const status = document.querySelector<HTMLSelectElement>('#artwork-status-filter')?.value ?? 'all';
      let visible = 0;
      for (const card of document.querySelectorAll<HTMLElement>('[data-artwork-id]')) {
        const matchesQuery = !query || (card.dataset.search ?? '').includes(query);
        const matchesStatus = status === 'all' || card.dataset.status === status;
        card.hidden = !(matchesQuery && matchesStatus);
        if (!card.hidden) visible += 1;
      }
      document.querySelector<HTMLElement>('#admin-empty-filter')!.hidden = visible > 0;
    }

    document.querySelector('#artwork-search')?.addEventListener('input', filterArtworks);
    document.querySelector('#artwork-status-filter')?.addEventListener('change', filterArtworks);

    const storedSecret = sessionStorage.getItem(sessionKey) || localStorage.getItem(persistentKey) || '';
    if (storedSecret) {
      secretInput.value = storedSecret;
      keepSignedIn.checked = Boolean(localStorage.getItem(persistentKey));
      enterAdmin(storedSecret);
    } else {
      secretInput.focus();
    }
  </script>
</Layout>
