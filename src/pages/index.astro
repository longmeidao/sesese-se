---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ArtworkViewer from '../components/ArtworkViewer.astro';
import { getArtworks, plainText } from '../lib/artworks';

const artworks = await getArtworks();
const artwork = artworks.at(-1);
---

<Layout
  title="色览"
  description={artwork ? `${artwork.title} — ${plainText(artwork.description) || `来自 ${artwork.author.name} 的作品`}` : '从 Pixiv 与其他图站采集、整理并展示值得停留的作品。'}
>
  <SiteHeader />
  {artwork ? (
    <ArtworkViewer artwork={artwork} total={artworks.length} />
  ) : (
    <main id="main-content" class="empty-state">
      <p>藏品室正在布置</p>
      <h1>还没有作品</h1>
      <p>运行「采集作品」工作流后，第一件作品会出现在这里。</p>
    </main>
  )}
</Layout>
