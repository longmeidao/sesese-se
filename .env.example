# Public origin used by generated HTML. Bind this custom domain to the object
# storage bucket; the default is https://media.sesese.se.
PUBLIC_MEDIA_ORIGIN=https://media.sesese.se

# Local ingestion only. In GitHub Actions, configure these as repository
# secrets/variables instead of committing a .env file.
PIXIV_REFRESH_TOKEN=
# Optional. When unset, X metadata uses the free, best-effort FxTwitter endpoint.
X_BEARER_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sesese-se-media

# Cloudflare Worker secrets used only by the Shortcut/API ingestion endpoint.
# GITHUB_TOKEN should be a fine-grained token limited to this repository with
# Actions read/write access. Keep both values out of wrangler.jsonc and Git.
GITHUB_TOKEN=
INGEST_WEBHOOK_SECRET=
